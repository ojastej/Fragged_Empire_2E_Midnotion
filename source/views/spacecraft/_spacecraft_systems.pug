section(data-i18n-aria-label="subsystems & rooms")
	h2(data-i18n='subsystems & rooms')
	+customControlFieldset({
		name:'spacecraftsystems'
		})
		.row
			+input({name:'cargo_used',
				type:'number',
				'data-i18n-placeholder':'Car',
				trigger:{affects:['cargo_space']}
				})
			+text({name:'name', 'data-i18n-placeholder':'Name'})
			+input({name:'influence_cost',
				type:'number',
				'data-i18n-placeholder':'Inf',
				trigger:{affects:['systems_influence_cost']}
				})
			+button({
				name:'post',
				type:'action',
				class:'material-icons',
				'data-18n':'w',
				'data-action':'post',
				trigger: { triggeredFuncs: ['postRepeating'] }
				})
		+textarea({
			name:'description',
			class:'span-3',
			'data-i18n-placeholder':'Description'
			})
