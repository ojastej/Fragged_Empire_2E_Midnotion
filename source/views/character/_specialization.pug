section(data-i18n-aria-label="specializations").narrow
	h2(data-i18n='specializations')
	.rule +2 to all non-Acquisition and non-Attack Rolls narratively connected to this topic.
	+customControlFieldset({
		name:'specializations'
		})
		.row
			+text({name:'specialization', 'data-i18n-placeholder':'Specialization'})
			+button({
				name:'post',
				type:'action',
				class:'material-icons',
				'data-18n':'w',
				'data-action':'post',
				trigger: { triggeredFuncs: ['postRepeating'] }
				})
