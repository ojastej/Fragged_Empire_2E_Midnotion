section(data-i18n-aria-label="trade")
	h2(data-i18n='acquisitions') Acquisitions
	+customControlFieldset({
		name:'tradegoods'
		})
		.row
			.select
				+select({name:'type'})
					+option({'data-i18n':'type',selected:''})
					+option({'data-i18n':'freight'})
					+option({'data-i18n':'loot'})
					+option({'data-i18n':'money'})
					+option({'data-i18n':'network'})
					+option({'data-i18n':'knowledge'})
					+option({'data-i18n':'research'})
			+text({name:'detail', 'data-i18n-placeholder':'Detail'})
			+input({name:'quantity',type:'number','data-i18n-placeholder':'#'})
			+button({
				name:'post',
				type:'action',
				class:'material-icons',
				'data-18n':'w',
				'data-action':'post',
				trigger: { triggeredFuncs: ['postRepeating'] }
				})
