section(data-i18n-aria-label="pc")
	h2(data-i18n='character')
	.grid.column-3
		label(for='character_name').input-label
			span(data-i18n='name')
		+text({name:'character_name'}).span-2

		label(for='species').input-label
			span(data-i18n='species')
		.select.span-2
			+select({name:'species'})
				+option({value:'','data-i18n':'select'})
				+option({value:'Corporation','data-i18n':'corporation'})
				+option({value:'Kaltoran','data-i18n':'kaltoran'})
				+option({value:'Legion','data-i18n':'legion'})
				+option({value:'Nephilim','data-i18n':'nephilim'})
				+option({value:'Palantor','data-i18n':'palantor'})
				+option({value:'Remnant','data-i18n':'remnant'})
				+option({value:'Twi-Far','data-i18n':'twifar'})
				+option({value:'Zhou','data-i18n':'zhou'})

		label(for='level').input-label
			span(data-i18n='level')
		.value
			+number({name:'level'})
			span.small.padded
				|+
			+number({name:'sessions'})
			span(data-i18n='sessions').small.padded
		+trait({name:'level_trait'})

		label(for='resources').input-label
			span(data-i18n='resources')
		.span-1
			+number({name:'resources'})
			+calculation(characterCalculated.resources_max)
		+trait({name:'resources_trait'})

		label(for='influence').input-label
			span(data-i18n='influence')
		.span-1
			+number({name:'influence'})
			+calculation(characterCalculated.influence_max)
		+trait({name:'influence_trait'})

		label(for='spare_time').input-label
			span(data-i18n='spare time')
		+number({name:'spare_time'}).span-2

		label(for='grit_rolls').input-label
			span(data-i18n='grit re-rolls')
		.span-2
			+number({name:'grit_rolls'})
			+calculation(characterCalculated.grit_rolls_max)

		label(for='equipment_slots').input-label
			span(data-i18n='equipment_slots')
		.nowrap.span-2
			+calculation(characterCalculated.equipment_slots)

		label(for='bodies').input-label
			span(data-i18n='bodies')
		+number({name:'bodies'}).span-2

